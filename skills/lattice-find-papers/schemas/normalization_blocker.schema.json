{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "normalization_blocker.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "blocker_id",
    "paper_id",
    "missing_item",
    "severity"
  ],
  "properties": {
    "blocker_id": {
      "type": "string"
    },
    "paper_id": {
      "type": "string"
    },
    "missing_item": {
      "type": "string"
    },
    "blocker_level": {
      "type": "string"
    },
    "why_it_blocks_comparison": {
      "type": "string"
    },
    "is_core_variable": {
      "type": [
        "boolean",
        "string"
      ]
    },
    "related_variable": {
      "type": "string"
    },
    "affected_observable": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "conclusion_threat"
      ]
    },
    "possible_resolution": {
      "type": "string"
    },
    "note": {
      "type": "string"
    }
  }
}
