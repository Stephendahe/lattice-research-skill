{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "citation_audit.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "claim_id",
    "claim_sentence",
    "support_level"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "claim_sentence": {
      "type": "string"
    },
    "paper_id": {
      "type": "string"
    },
    "citation": {
      "type": "string"
    },
    "doi": {
      "type": "string"
    },
    "source_location": {
      "type": "string"
    },
    "what_the_paper_actually_supports": {
      "type": "string"
    },
    "support_level": {
      "type": "string",
      "enum": [
        "direct_support",
        "indirect_support",
        "background_only",
        "unsupported",
        "contradiction"
      ]
    },
    "problem": {
      "type": "string"
    },
    "action": {
      "type": "string"
    }
  }
}
